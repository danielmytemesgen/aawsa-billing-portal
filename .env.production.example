# AAWSA Billing Portal - Production Environment Variables
# Copy this file to .env.production and fill in the real values on the server.
# NEVER commit .env.production to git.

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=aawsa_billing
POSTGRES_PORT=5432

# Application Settings
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
# Set this to your Windows Server IP address (e.g. 10.10.254.78)
PUBLIC_SERVER_IP=YOUR_SERVER_IP_HERE
# Set to true only if you are deploying with HTTPS/SSL. If using HTTP, keep this as false.
ENABLE_HSTS=false

# API Keys and Secrets
GOOGLE_API_KEY=your_google_api_key_here
# Must be at least 32 characters. Generate with: openssl rand -hex 32
SESSION_SECRET=generate_a_strong_random_secret_here_minimum_32_chars
INTERNAL_API_KEY=generate_a_strong_random_key_here

# Application URL — MUST match what users type in the browser.
# Use http:// for plain IP/intranet, https:// only if you have SSL configured.
NEXTAUTH_URL=http://YOUR_SERVER_IP_HERE:3000
